#!/usr/bin/env bash

up_icon="uk-brightness-high.svg"
down_icon="uk-brightness-low.svg"
reset_icon="uk-brightness-medium.svg"

_check() {
    command -v "$1" >/dev/null
}

DEFAULT_BRIGHTNESS="0.85"
CONFIG_FILE="/home/ukiran/.config/my_display/brightness"
PIPE_FILE="/tmp/.brightness-pipe"
DISPLAY_OUTPUT="HDMI-1-0"

if [[ ! -p $PIPE_FILE ]]; then
    mkfifo "$PIPE_FILE" || {
        echo "Error: Could not create pipe $PIPE_FILE" >&2
        exit 1
    }
fi

get_brightness() {
    awk '{print $1 * 100}' $CONFIG_FILE | tee /tmp/.brightness-pipe
}

send_notification() {
    local percentage=$1
    local icon_path=$2

    dunstify -a "ignore" -u low -r 4434 -h int:value:"$percentage" \
        -i "$icon_path" "Brightness: ${percentage}%" -t 2000
}

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Config not found: $CONFIG_FILE" >&2
    exit 1
fi

# Read the current brightness value from the config file
read -r current_brightness < "$CONFIG_FILE" || {
    echo "Error: Could not read from config file $CONFIG_FILE" >&2
    exit 1
}

# if [[ $# -eq 0 ]]; then
#     xrandr --output "$DISPLAY_OUTPUT" --brightness "$current_brightness"
#     echo "$current_brightness"
#     exit 0
# fi

case "$1" in
    up)
        if (( $(echo "$current_brightness < 1.0" | bc -l) )); then
            new_brightness=$(echo "$current_brightness + 0.05" | bc -l)
            if (( $(echo "$new_brightness > 1.0" | bc -l) )); then
                new_brightness="1.0"
            fi
            echo "$new_brightness" > "$CONFIG_FILE"
            xrandr --output "$DISPLAY_OUTPUT" --brightness "$new_brightness"
            percentage=$(awk '{printf "%.0f", $1 * 100}' <<< "$new_brightness")
            send_notification "$percentage" "$up_icon"
        fi
        ;;
    down)
        if (( $(echo "$current_brightness > 0.1" | bc -l) )); then
            new_brightness=$(echo "$current_brightness - 0.05" | bc -l)
            if (( $(echo "$new_brightness < 0.1" | bc -l) )); then
                new_brightness="0.1"
            fi
            echo "$new_brightness" > "$CONFIG_FILE"
            xrandr --output "$DISPLAY_OUTPUT" --brightness "$new_brightness"
            percentage=$(awk '{printf "%.0f", $1 * 100}' <<< "$new_brightness")
            send_notification "$percentage" "$down_icon"
        fi
        ;;
    reset)
        new_brightness="$DEFAULT_BRIGHTNESS"
        echo "$new_brightness" > "$CONFIG_FILE"
        xrandr --output "$DISPLAY_OUTPUT" --brightness "$new_brightness"
        percentage=$(awk '{printf "%.0f", $1 * 100}' <<< "$new_brightness")
        send_notification "$percentage" "$reset_icon"
        ;;
esac

# Update the pipe with the new brightness value
get_brightness
