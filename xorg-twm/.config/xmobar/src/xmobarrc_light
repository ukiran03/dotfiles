      , Run Date "%a, %d %b %Y, <fc=#3f578f>%I:%M %p (%R)</fc>" "date" 300
      , Run Com ".config/xmobar/scripts/trayer-padding-icon.sh" [] "trayerpad" 30
      , Run Com ".config/xmobar/xbps-updates.sh" [] "xbps" 3600
      , Run Com "pamixer" ["--get-volume-human"] "" 20
      , Run Alsa "default" "Master" ["-t", "<status> <volume>%","--"
                                    , "-O", "<fc=#0031a9><fn=1> </fn></fc>"
                                    , "-o", "<fc=#a60000><fn=1> </fn></fc>"]
      , Run MPD ["-t", "<state>: <artist> - <track>"] 10
      , Run XMonadLog
